# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: deps
# ═══════════════════════════════════════════════════════════════════════════════

cmd_deps() {
    local action="menu"
    local target="both"
    
    # Parse sub-args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check|-c)   action="check" ;;
            --install|-i) action="install" ;;
            --remove|-r)  action="remove" ;;
            --client)     target="client" ;;
            --server)     target="server" ;;
            --both)       target="both" ;;
            --help|-h)
                echo "Usage: luantis deps [--check|--install|--remove] [--client|--server|--both]"
                return 0
                ;;
        esac
        shift
    done
    
    case "$action" in
        check)  deps_check "$target" ;;
        install) deps_install "$target" ;;
        remove) deps_remove ;;
        menu)   deps_menu "$target" ;;
    esac
}

deps_check() {
    local target="${1:-both}"
    
    clear_screen
    draw_box "DEPENDENCY CHECK" 60 "${CYAN}"
    echo ""
    kv "Distribution" "$DISTRO"
    kv "Target" "$target"
    # Show if user-space prefix is active
    if [[ -d "${LOCAL_PREFIX}" ]]; then
        kv "User Prefix" "${LOCAL_PREFIX}"
    fi
    echo ""
    draw_hr 60
    echo ""
    
    local total=0
    local found=0
    local missing=0
    local -a missing_list=()
    
    # Check build tools
    echo -e "  ${BOLD}Build Tools:${NC}"
    for tool in "${CORE_DEPS_TOOLS[@]}"; do
        total=$((total + 1))
        if command -v "$tool" &>/dev/null; then
            echo -e "    ${BGREEN}✓${NC} ${tool}  $(command -v "$tool")"
            found=$((found + 1))
        else
            local pkg
            pkg="$(lib_to_pkg "$tool")"
            echo -e "    ${BRED}✗${NC} ${tool}  ${DIM}(install: ${pkg})${NC}"
            missing=$((missing + 1))
            missing_list+=("$pkg")
        fi
    done
    echo ""
    
    # Check core libraries
    echo -e "  ${BOLD}Core Libraries:${NC}"
    for lib in "${CORE_DEPS_LIBS[@]}"; do
        total=$((total + 1))
        if pc_exists "$lib" 2>/dev/null; then
            local ver
            ver="$(pc_modversion "$lib")"
            echo -e "    ${BGREEN}✓${NC} ${lib}  ${DIM}${ver}${NC}"
            found=$((found + 1))
        else
            local pkg
            pkg="$(lib_to_pkg "$lib")"
            echo -e "    ${BRED}✗${NC} ${lib}  ${DIM}(install: ${pkg})${NC}"
            missing=$((missing + 1))
            missing_list+=("$pkg")
        fi
    done
    echo ""
    
    # Check client dependencies
    if [[ "$target" == "client" || "$target" == "both" ]]; then
        echo -e "  ${BOLD}Client Libraries:${NC}"
        for lib in "${CLIENT_DEPS_LIBS[@]}"; do
            total=$((total + 1))
            if pc_exists "$lib" 2>/dev/null; then
                local ver
                ver="$(pc_modversion "$lib")"
                echo -e "    ${BGREEN}✓${NC} ${lib}  ${DIM}${ver}${NC}"
                found=$((found + 1))
            else
                local pkg
                pkg="$(lib_to_pkg "$lib")"
                echo -e "    ${BRED}✗${NC} ${lib}  ${DIM}(install: ${pkg})${NC}"
                missing=$((missing + 1))
                missing_list+=("$pkg")
            fi
        done
        echo ""
    fi
    
    # Check server dependencies
    if [[ "$target" == "server" || "$target" == "both" ]]; then
        echo -e "  ${BOLD}Server Libraries:${NC}"
        for lib in "${SERVER_DEPS_LIBS[@]}"; do
            total=$((total + 1))
            if pc_exists "$lib" 2>/dev/null; then
                local ver
                ver="$(pc_modversion "$lib")"
                echo -e "    ${BGREEN}✓${NC} ${lib}  ${DIM}${ver}${NC}"
                found=$((found + 1))
            else
                local pkg
                pkg="$(lib_to_pkg "$lib")"
                echo -e "    ${BRED}✗${NC} ${lib}  ${DIM}(install: ${pkg})${NC}"
                missing=$((missing + 1))
                missing_list+=("$pkg")
            fi
        done
        echo ""
    fi
    
    draw_hr 60
    echo ""
    progress_bar "$found" "$total" 40 "Dependencies"
    echo ""
    
    if [[ "$missing" -eq 0 ]]; then
        success "All dependencies satisfied!"
    else
        warn "${missing} missing dependencies"
        echo ""
        echo -e "  ${BOLD}Install command:${NC}"
        echo -e "  ${CYAN}./luantis deps --install${NC}"
        echo ""
        if [[ "${#missing_list[@]}" -gt 0 ]]; then
            # De-duplicate missing packages (e.g., curl in both client/server deps)
            declare -A seen_missing
            local -a unique_missing=()
            for pkg in "${missing_list[@]}"; do
                if [[ -z "${seen_missing[$pkg]:-}" ]]; then
                    seen_missing[$pkg]=1
                    unique_missing+=("$pkg")
                fi
            done
            echo -e "  ${DIM}Missing packages: ${unique_missing[*]}${NC}"
        fi
    fi
    
    draw_box_end 60 "${CYAN}"
    echo ""
}

deps_install() {
    local target="${1:-both}"
    
    clear_screen
    draw_box "INSTALL DEPENDENCIES" 60 "${GREEN}"
    echo ""
    kv "Distribution" "$DISTRO"
    kv "Target" "$target"
    echo ""
    
    # Collect missing packages
    local -a missing_pkgs=()
    
    for tool in "${CORE_DEPS_TOOLS[@]}"; do
        if ! command -v "$tool" &>/dev/null; then
            local pkg
            pkg="$(lib_to_pkg "$tool")"
            [[ -n "$pkg" ]] && missing_pkgs+=("$pkg")
        fi
    done
    
    for lib in "${CORE_DEPS_LIBS[@]}"; do
        if ! pc_exists "$lib" 2>/dev/null; then
            local pkg
            pkg="$(lib_to_pkg "$lib")"
            [[ -n "$pkg" ]] && missing_pkgs+=("$pkg")
        fi
    done
    
    if [[ "$target" == "client" || "$target" == "both" ]]; then
        for lib in "${CLIENT_DEPS_LIBS[@]}"; do
            if ! pc_exists "$lib" 2>/dev/null; then
                local pkg
                pkg="$(lib_to_pkg "$lib")"
                [[ -n "$pkg" ]] && missing_pkgs+=("$pkg")
            fi
        done
    fi
    
    if [[ "$target" == "server" || "$target" == "both" ]]; then
        for lib in "${SERVER_DEPS_LIBS[@]}"; do
            if ! pc_exists "$lib" 2>/dev/null; then
                local pkg
                pkg="$(lib_to_pkg "$lib")"
                [[ -n "$pkg" ]] && missing_pkgs+=("$pkg")
            fi
        done
    fi
    
    if [[ "${#missing_pkgs[@]}" -eq 0 ]]; then
        success "All dependencies already installed!"
        draw_box_end 60 "${GREEN}"
        return 0
    fi
    
    # De-duplicate package list (e.g., curl appears in both client and server deps)
    local -a unique_pkgs=()
    declare -A seen_pkgs
    for pkg in "${missing_pkgs[@]}"; do
        if [[ -z "${seen_pkgs[$pkg]:-}" ]]; then
            seen_pkgs[$pkg]=1
            unique_pkgs+=("$pkg")
        fi
    done
    missing_pkgs=("${unique_pkgs[@]}")
    
    echo -e "  ${BOLD}Packages to install (${#missing_pkgs[@]}):${NC}"
    echo ""
    local col=0
    for pkg in "${missing_pkgs[@]}"; do
        printf "    ${GREEN}+${NC} %-24s" "$pkg"
        col=$((col + 1))
        if [[ "$col" -ge 3 ]]; then
            echo ""
            col=0
        fi
    done
    [[ "$col" -gt 0 ]] && echo ""
    echo ""
    
    if ! confirm "Install these packages?" "n"; then
        warn "Installation cancelled."
        draw_box_end 60 "${GREEN}"
        return 1
    fi
    
    echo ""
    install_packages "${missing_pkgs[@]}" && {
        success "Dependencies installed successfully!"
        # Save manifest
        echo "# Luantis build deps installed by luantis CLI" > "$DEPS_MANIFEST"
        echo "# Generated: $(date)" >> "$DEPS_MANIFEST"
        echo "# Distro: ${DISTRO}" >> "$DEPS_MANIFEST"
        for pkg in "${missing_pkgs[@]}"; do
            echo "$pkg" >> "$DEPS_MANIFEST"
        done
    } || {
        fail "Failed to install some packages."
    }
    
    draw_box_end 60 "${GREEN}"
    echo ""
}

deps_remove() {
    clear_screen
    draw_box "REMOVE BUILD DEPENDENCIES" 60 "${RED}"
    echo ""
    
    if ! confirm "${BRED}Remove all build dependencies?${NC} This may affect other software." "n"; then
        info "Removal cancelled."
        draw_box_end 60 "${RED}"
        return 0
    fi
    
    # Collect all possible packages from deps manifest
    local -a all_pkgs=()
    if [[ -f "$DEPS_MANIFEST" ]]; then
        while IFS= read -r line; do
            [[ "$line" =~ ^# ]] && continue
            [[ -z "$line" ]] && continue
            all_pkgs+=("$line")
        done < "$DEPS_MANIFEST"
    fi
    
    if [[ "${#all_pkgs[@]}" -eq 0 ]]; then
        info "No dependency manifest found. Nothing to remove."
        draw_box_end 60 "${RED}"
        return 0
    fi
    
    # Filter to actually installed
    local -a installed_pkgs=()
    for pkg in "${all_pkgs[@]}"; do
        if pkg_is_installed "$pkg"; then
            installed_pkgs+=("$pkg")
        fi
    done
    
    if [[ "${#installed_pkgs[@]}" -eq 0 ]]; then
        info "No tracked packages are currently installed."
        draw_box_end 60 "${RED}"
        return 0
    fi
    
    step "Removing ${#installed_pkgs[@]} packages..."
    case "$DISTRO" in
        debian|ubuntu|linuxmint|pop|elementary|kali)
            sudo apt-get remove -y "${installed_pkgs[@]}" 2>&1 | tail -5
            sudo apt-get autoremove -y 2>&1 | tail -3
            ;;
        fedora|rhel|centos|rocky|alma|oracle)
            sudo dnf remove -y "${installed_pkgs[@]}" 2>&1 | tail -5
            ;;
        arch|manjaro|endeavouros|garuda)
            sudo pacman -Rns --noconfirm "${installed_pkgs[@]}" 2>&1 | tail -5
            ;;
        alpine)
            sudo apk del "${installed_pkgs[@]}" 2>&1 | tail -5
            ;;
    esac
    
    rm -f "$DEPS_MANIFEST"
    success "Build dependencies removed."
    draw_box_end 60 "${RED}"
    echo ""
}

deps_menu() {
    local target="${1:-both}"
    
    clear_screen
    draw_box "DEPENDENCY MANAGEMENT" 60 "${CYAN}"
    echo ""
    menu_item "1" "Check dependencies" "Scan and show status of all deps"
    menu_item "2" "Install missing" "Auto-install all missing deps"
    menu_item "3" "Remove all" "Remove previously installed build deps"
    menu_item "q" "Back" "Return to main menu"
    echo ""
    draw_box_end 60 "${CYAN}"
    echo ""
    
    read -rp "  ${BOLD}Select [1-3,q]:${NC} " choice
    case "$choice" in
        1) cmd_deps --check --"$target" ;;
        2) cmd_deps --install --"$target" ;;
        3) cmd_deps --remove ;;
        q|Q) return 0 ;;
        *)  echo -e "  ${RED}Invalid choice${NC}"; sleep 1 ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: build
# ═══════════════════════════════════════════════════════════════════════════════

cmd_build() {
    local target="both"
    local build_type="Release"
    local do_clean=0
    local run_in_place=1
    local jobs="$(nproc 2>/dev/null || echo 4)"
    local local_prefix=""
    local do_check_deps=1
    local verbose=0
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --client|-c)  target="client" ;;
            --server|-s)  target="server" ;;
            --both|-b)    target="both" ;;
            --release)    build_type="Release" ;;
            --debug)      build_type="Debug" ;;
            --clean)      do_clean=1 ;;
            --no-check-deps) do_check_deps=0 ;;
            --jobs|-j)    jobs="$2"; shift ;;
            --local-prefix) local_prefix="$2"; shift ;;
            --verbose|-v) verbose=1 ;;
            --help|-h)
                echo "Usage: luantis build [--client|--server|--both] [--release|--debug] [--clean] [--jobs N]"
                return 0
                ;;
        esac
        shift
    done
    
    # Interactive target selection if not specified
    if [[ $# -eq 0 ]] && [[ -t 0 ]]; then
        clear_screen
        draw_box "BUILD CONFIGURATION" 60 "${MAGENTA}"
        echo ""
        menu_item "1" "Client only" "Build the graphical game client"
        menu_item "2" "Server only" "Build the headless dedicated server"
        menu_item "3" "Both" "Build client and server (full build)"
        echo ""
        draw_box_end 60 "${MAGENTA}"
        echo ""
        
        read -rp "  ${BOLD}Select build target [1-3] (default: 3):${NC} " choice
        case "$choice" in
            1) target="client" ;;
            2) target="server" ;;
            3|"") target="both" ;;
        esac
        
        echo ""
        read -rp "  ${BOLD}Build type [1=Release, 2=Debug] (default: 1):${NC} " bt_choice
        case "$bt_choice" in
            2) build_type="Debug" ;;
            *) build_type="Release" ;;
        esac
        
        echo ""
        if confirm "Clean build directory first?" "n"; then
            do_clean=1
        fi
    fi
    
    # Check deps first
    if [[ "$do_check_deps" -eq 1 ]]; then
        step "Checking dependencies..."
        local missing=0
        
        for tool in "${CORE_DEPS_TOOLS[@]}"; do
            if ! command -v "$tool" &>/dev/null; then
                missing=$((missing + 1))
            fi
        done
        for lib in "${CORE_DEPS_LIBS[@]}"; do
            if ! pc_exists "$lib" 2>/dev/null; then
                missing=$((missing + 1))
            fi
        done
        
        if [[ "$target" == "client" || "$target" == "both" ]]; then
            for lib in "${CLIENT_DEPS_LIBS[@]}"; do
                if ! pc_exists "$lib" 2>/dev/null; then
                    missing=$((missing + 1))
                fi
            done
        fi
        
        if [[ "$target" == "server" || "$target" == "both" ]]; then
            for lib in "${SERVER_DEPS_LIBS[@]}"; do
                if ! pc_exists "$lib" 2>/dev/null; then
                    missing=$((missing + 1))
                fi
            done
        fi
        
        if [[ "$missing" -gt 0 ]]; then
            warn "${missing} missing dependencies detected!"
            if confirm "Install missing dependencies now?" "y"; then
                cmd_deps --install --"$target" || return 1
            else
                error "Cannot build without dependencies. Aborting."
                return 1
            fi
        else
            success "All dependencies satisfied."
        fi
    fi
    
    # Clean if requested
    if [[ "$do_clean" -eq 1 ]]; then
        step "Cleaning build directory..."
        rm -rf "$BUILD_DIR"
        success "Build directory cleaned."
    fi
    
    # Create build directory
    mkdir -p "$BUILD_DIR"
    
    # Build cmake arguments
    local -a cmake_args=(
        -DCMAKE_BUILD_TYPE="$build_type"
        -DBUILD_UNITTESTS=TRUE
        -DRUN_IN_PLACE=TRUE
    )
    
    case "$target" in
        client) cmake_args+=(-DBUILD_CLIENT=1 -DBUILD_SERVER=0) ;;
        server) cmake_args+=(-DBUILD_CLIENT=0 -DBUILD_SERVER=1) ;;
        both)   cmake_args+=(-DBUILD_CLIENT=1 -DBUILD_SERVER=1) ;;
    esac
    
    # Local prefix for user-space deps
    if [[ -z "$local_prefix" ]]; then
        # Use the globally detected LOCAL_PREFIX (which checks local-prefix/ then build/prefix/)
        if [[ -n "${LOCAL_PREFIX}" ]]; then
            local_prefix="${LOCAL_PREFIX}"
        fi
    fi
    
    if [[ -n "$local_prefix" ]]; then
        # Collect all library directories from the prefix (handles both lib/ and usr/lib/... layouts)
        local -a prefix_lib_dirs=()
        for d in "${local_prefix}/lib" "${local_prefix}/usr/lib/x86_64-linux-gnu" "${local_prefix}/lib/x86_64-linux-gnu"; do
            [[ -d "$d" ]] && prefix_lib_dirs+=("$d")
        done

        local linker_lib_flags=""
        for d in "${prefix_lib_dirs[@]}"; do
            linker_lib_flags+=" -L${d}"
        done

        # CMAKE_PREFIX_PATH needs to include both the prefix root and usr/ subdirectory
        # (deb-extracted packages put headers in usr/include and libs in usr/lib/)
        local cmake_prefix_path="$local_prefix"
        if [[ -d "${local_prefix}/usr" ]]; then
            cmake_prefix_path="${local_prefix}/usr;${local_prefix}"
        fi

        cmake_args+=(
            -DCMAKE_PREFIX_PATH="${cmake_prefix_path}"
            -DCMAKE_EXE_LINKER_FLAGS="-L/usr/lib/x86_64-linux-gnu${linker_lib_flags} -Wl,--no-as-needed -lbrotlidec -lbrotlicommon"
            -DUSE_SHARED_FREETYPE=ON
        )

        # Also set PKG_CONFIG_PATH so CMake's FindPkgConfig can locate prefix .pc files
        local -a pc_dirs=()
        for d in "${prefix_lib_dirs[@]}"; do
            [[ -d "${d}/pkgconfig" ]] && pc_dirs+=("${d}/pkgconfig")
        done
        if [[ "${#pc_dirs[@]}" -gt 0 ]]; then
            local joined_pc
            joined_pc="$(IFS=:; echo "${pc_dirs[*]}")"
            cmake_args+=(-DPKG_CONFIG_PATH="${joined_pc}:${PKG_CONFIG_PATH:-}")
        fi
    fi
    
    # Show build summary
    clear_screen
    draw_box "BUILDING LUANTIS" 60 "${MAGENTA}"
    echo ""
    kv "Target" "$target" "${MAGENTA}"
    kv "Build Type" "$build_type" "${MAGENTA}"
    kv "Jobs" "$jobs" "${MAGENTA}"
    kv "Run In Place" "yes" "${MAGENTA}"
    [[ -n "$local_prefix" ]] && kv "Local Prefix" "$local_prefix" "${MAGENTA}"
    kv "Build Dir" "$BUILD_DIR" "${MAGENTA}"
    echo ""
    draw_hr 60
    echo ""
    
    # Configure
    step "Running CMake configuration..."
    cd "$BUILD_DIR"
    if ! cmake .. "${cmake_args[@]}" 2>&1 | tee -a "$LOG_FILE"; then
        fail "CMake configuration failed!"
        cd "$SCRIPT_DIR"
        return 1
    fi
    success "CMake configuration complete."
    echo ""
    
    # Build
    step "Building with ${jobs} parallel jobs..."
    echo ""
    
    local build_target=""
    case "$target" in
        client) build_target="luanti" ;;
        server) build_target="luantiserver" ;;
        both)   build_target="" ;;  # Build all
    esac
    
    local -a build_cmd=(cmake --build . --parallel "$jobs")
    [[ -n "$build_target" ]] && build_cmd+=("--target" "$build_target")
    
    # Use process substitution to preserve the build command's exit code
    # (pipefail alone is insufficient because tee may succeed even if build fails,
    #  and grep filtering can swallow the real exit code)
    local build_result=0
    if [[ "$verbose" -eq 1 ]]; then
        "${build_cmd[@]}" 2>&1 | tee -a "$LOG_FILE" || build_result=$?
    else
        "${build_cmd[@]}" 2>&1 | tee -a "$LOG_FILE" | grep -E '(error|Error|warning|Warning|\[.*%\])' || true
        # grep may mask the real exit code; check the binary existence instead
    fi
    
    # If tee reported success, verify the binary actually exists as a sanity check
    if [[ "$build_result" -eq 0 ]]; then
        case "$target" in
            client)
                [[ -x "${BIN_DIR}/luanti" ]] || build_result=1
                ;;
            server)
                [[ -x "${BIN_DIR}/luantiserver" ]] || build_result=1
                ;;
            both)
                { [[ -x "${BIN_DIR}/luanti" ]] && [[ -x "${BIN_DIR}/luantiserver" ]]; } || build_result=1
                ;;
        esac
    fi
    cd "$SCRIPT_DIR"
    
    echo ""
    if [[ "$build_result" -eq 0 ]]; then
        success "Build completed successfully!"
        echo ""
        
        # Show binary locations
        local client_bin server_bin
        client_bin="$(find_client_binary 2>/dev/null)" || true
        server_bin="$(find_server_binary 2>/dev/null)" || true
        
        [[ -n "$client_bin" ]] && kv "Client" "$client_bin" "${GREEN}" "${GREEN}"
        [[ -n "$server_bin" ]] && kv "Server" "$server_bin" "${GREEN}" "${GREEN}"
    else
        fail "Build failed with exit code ${build_result}."
        echo -e "  ${DIM}Check log: ${LOG_FILE}${NC}"
    fi
    
    draw_box_end 60 "${MAGENTA}"
    echo ""
    return $build_result
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: start
# ═══════════════════════════════════════════════════════════════════════════════

cmd_start() {
    local what="${1:-}"
    shift 2>/dev/null || true
    
    if [[ -z "$what" ]]; then
        clear_screen
        draw_box "START LUANTIS" 60 "${GREEN}"
        echo ""
        menu_item "1" "Start Server" "Launch the Luanti dedicated server"
        menu_item "2" "Start Client" "Launch the Luanti game client"
        echo ""
        draw_box_end 60 "${GREEN}"
        echo ""
        
        read -rp "  ${BOLD}Select [1-2]:${NC} " choice
        case "$choice" in
            1) what="server" ;;
            2) what="client" ;;
            *) return 0 ;;
        esac
    fi
    
    case "$what" in
        server) cmd_start_server "$@" ;;
        client) cmd_start_client "$@" ;;
        *)
            error "Unknown target: $what. Use 'server' or 'client'."
            return 1
            ;;
    esac
}

cmd_start_server() {
    # Delegate to start_server.sh with all args
    if [[ -f "${SCRIPT_DIR}/start_server.sh" ]]; then
        exec "${SCRIPT_DIR}/start_server.sh" "$@"
    else
        error "start_server.sh not found!"
        return 1
    fi
}

cmd_start_client() {
    # Delegate to start_client.sh with all args
    if [[ -f "${SCRIPT_DIR}/start_client.sh" ]]; then
        exec "${SCRIPT_DIR}/start_client.sh" "$@"
    else
        error "start_client.sh not found!"
        return 1
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: stop
# ═══════════════════════════════════════════════════════════════════════════════

cmd_stop() {
    local port="${1:-30000}"
    
    step "Stopping Luanti server on port ${port}..."
    
    # Find PID
    local pid
    pid="$(pgrep -f "luantiserver.*--port ${port}" 2>/dev/null | head -1)" || true
    
    # Also check PID file
    local pfile="/tmp/luantiserver-${port}.pid"
    if [[ -f "$pfile" ]]; then
        local file_pid
        file_pid="$(cat "$pfile" 2>/dev/null)" || true
        [[ -n "$file_pid" ]] && pid="$file_pid"
    fi
    
    if [[ -z "$pid" ]]; then
        warn "No server found on port ${port}."
        return 0
    fi
    
    if ! kill -0 "$pid" 2>/dev/null; then
        info "Process ${pid} is not running. Cleaning up."
        rm -f "$pfile"
        return 0
    fi
    
    step "Sending SIGTERM to PID ${pid}..."
    kill "$pid" 2>/dev/null
    
    local waited=0
    while kill -0 "$pid" 2>/dev/null && [[ "$waited" -lt 10 ]]; do
        sleep 1
        waited=$((waited + 1))
        printf "\r  Waiting... %ds" "$waited"
    done
    echo ""
    
    if kill -0 "$pid" 2>/dev/null; then
        warn "Server did not stop gracefully. Force killing..."
        kill -9 "$pid" 2>/dev/null || true
    fi
    
    rm -f "$pfile"
    success "Server stopped."
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: status
# ═══════════════════════════════════════════════════════════════════════════════

cmd_status() {
    clear_screen
    draw_box "LUANTIS STATUS" 60 "${CYAN}"
    echo ""
    
    # Version info
    kv "Version" "$(get_version)"
    kv "Git Branch" "$(get_git_branch)"
    kv "Git Status" "$(get_git_status)"
    kv "Distribution" "$DISTRO"
    echo ""
    draw_hr 60
    echo ""
    
    # Binary status
    echo -e "  ${BOLD}Binaries:${NC}"
    local client_bin server_bin
    client_bin="$(find_client_binary 2>/dev/null)" || true
    server_bin="$(find_server_binary 2>/dev/null)" || true
    
    if [[ -n "$client_bin" ]]; then
        echo -e "    ${BGREEN}✓${NC} Client: ${client_bin}"
    else
        echo -e "    ${BRED}✗${NC} Client: ${DIM}not built${NC}"
    fi
    
    if [[ -n "$server_bin" ]]; then
        echo -e "    ${BGREEN}✓${NC} Server: ${server_bin}"
    else
        echo -e "    ${BRED}✗${NC} Server: ${DIM}not built${NC}"
    fi
    echo ""
    
    # Running server processes
    echo -e "  ${BOLD}Running Servers:${NC}"
    local found=0
    for pfile in /tmp/luantiserver-*.pid; do
        [[ -f "$pfile" ]] || continue
        found=1
        local pid
        pid="$(cat "$pfile" 2>/dev/null || echo "?")"
        local port
        port="$(basename "$pfile" .pid | sed 's/luantiserver-//')"
        local status="stopped"
        [[ "$pid" != "?" ]] && kill -0 "$pid" 2>/dev/null && status="running"
        
        local status_color="${BGREEN}"
        [[ "$status" == "stopped" ]] && status_color="${BRED}"
        
        echo -e "    Port ${port}: ${status_color}${status}${NC} (PID: ${pid})"
    done
    
    # Also check for running processes without PID files
    local running_pids
    running_pids="$(pgrep -f "luantiserver" 2>/dev/null)" || true
    if [[ -n "$running_pids" ]] && [[ "$found" -eq 0 ]]; then
        for pid in $running_pids; do
            echo -e "    ${YELLOW}?${NC} PID: ${pid} (no PID file)"
        done
        found=1
    fi
    
    if [[ "$found" -eq 0 ]]; then
        echo -e "    ${DIM}No running servers${NC}"
    fi
    echo ""
    
    # Build directory
    echo -e "  ${BOLD}Build Directory:${NC}"
    if [[ -d "$BUILD_DIR" ]]; then
        local cache_exists="no"
        [[ -f "${BUILD_DIR}/CMakeCache.txt" ]] && cache_exists="yes"
        echo -e "    Exists: ${BGREEN}yes${NC}  CMake Cache: ${cache_exists}"
        
        if [[ -f "${BUILD_DIR}/CMakeCache.txt" ]]; then
            local cached_type
            cached_type="$(grep 'CMAKE_BUILD_TYPE:' "${BUILD_DIR}/CMakeCache.txt" 2>/dev/null | sed 's/.*=//' || echo '?')"
            local cached_client
            cached_client="$(grep 'BUILD_CLIENT:' "${BUILD_DIR}/CMakeCache.txt" 2>/dev/null | sed 's/.*=//' || echo '?')"
            local cached_server
            cached_server="$(grep 'BUILD_SERVER:' "${BUILD_DIR}/CMakeCache.txt" 2>/dev/null | sed 's/.*=//' || echo '?')"
            echo -e "    Type: ${cached_type}  Client: ${cached_client}  Server: ${cached_server}"
        fi
    else
        echo -e "    ${DIM}Not created yet (run: ./luantis build)${NC}"
    fi
    echo ""
    
    # Worlds
    echo -e "  ${BOLD}Worlds:${NC}"
    if [[ -d "$WORLD_BASE_DIR" ]]; then
        local world_count
        world_count="$(find "$WORLD_BASE_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)"
        echo -e "    ${world_count} world(s) in ${WORLD_BASE_DIR}"
    else
        echo -e "    ${DIM}No worlds directory${NC}"
    fi
    echo ""
    
    # Dependency status
    echo -e "  ${BOLD}Quick Dependency Check:${NC}"
    local missing=0
    for tool in "${CORE_DEPS_TOOLS[@]}"; do
        if ! command -v "$tool" &>/dev/null; then
            missing=$((missing + 1))
        fi
    done
    for lib in "${CORE_DEPS_LIBS[@]}"; do
        if ! pc_exists "$lib" 2>/dev/null; then
            missing=$((missing + 1))
        fi
    done
    
    if [[ "$missing" -eq 0 ]]; then
        echo -e "    ${BGREEN}✓${NC} All core dependencies installed"
    else
        echo -e "    ${BRED}✗${NC} ${missing} missing — run ${CYAN}./luantis deps --check${NC}"
    fi
    echo ""
    
    draw_box_end 60 "${CYAN}"
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: test
# ═══════════════════════════════════════════════════════════════════════════════

cmd_test() {
    local suite="all"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --all|-a)      suite="all" ;;
            --build|-b)    suite="build" ;;
            --encryption|-e) suite="encryption" ;;
            --log|-l)      suite="log" ;;
            --fixes|-f)    suite="fixes" ;;
            --help|-h)
                echo "Usage: luantis test [--all|--build|--encryption|--log|--fixes]"
                return 0
                ;;
        esac
        shift
    done
    
    clear_screen
    draw_box "TEST SUITES" 60 "${YELLOW}"
    echo ""
    
    local -a test_scripts=()
    
    case "$suite" in
        all)
            [[ -f "${SCRIPT_DIR}/test_build_linux.sh" ]] && test_scripts+=("${SCRIPT_DIR}/test_build_linux.sh")
            [[ -f "${SCRIPT_DIR}/test_encryption_toggle.sh" ]] && test_scripts+=("${SCRIPT_DIR}/test_encryption_toggle.sh")
            [[ -f "${SCRIPT_DIR}/test_log_toggle.sh" ]] && test_scripts+=("${SCRIPT_DIR}/test_log_toggle.sh")
            [[ -f "${SCRIPT_DIR}/test_fixes.sh" ]] && test_scripts+=("${SCRIPT_DIR}/test_fixes.sh")
            [[ -f "${SCRIPT_DIR}/test_start_server.sh" ]] && test_scripts+=("${SCRIPT_DIR}/test_start_server.sh")
            [[ -f "${SCRIPT_DIR}/test_start_client.sh" ]] && test_scripts+=("${SCRIPT_DIR}/test_start_client.sh")
            ;;
        build)
            [[ -f "${SCRIPT_DIR}/test_build_linux.sh" ]] && test_scripts+=("${SCRIPT_DIR}/test_build_linux.sh")
            ;;
        encryption)
            [[ -f "${SCRIPT_DIR}/test_encryption_toggle.sh" ]] && test_scripts+=("${SCRIPT_DIR}/test_encryption_toggle.sh")
            ;;
        log)
            [[ -f "${SCRIPT_DIR}/test_log_toggle.sh" ]] && test_scripts+=("${SCRIPT_DIR}/test_log_toggle.sh")
            ;;
        fixes)
            [[ -f "${SCRIPT_DIR}/test_fixes.sh" ]] && test_scripts+=("${SCRIPT_DIR}/test_fixes.sh")
            ;;
    esac
    
    if [[ "${#test_scripts[@]}" -eq 0 ]]; then
        warn "No test scripts found."
        draw_box_end 60 "${YELLOW}"
        return 1
    fi
    
    local total_passed=0
    local total_failed=0
    
    for script in "${test_scripts[@]}"; do
        local name
        name="$(basename "$script")"
        echo -e "  ${BOLD}Running: ${name}${NC}"
        echo ""
        
        if bash "$script" 2>&1; then
            success "  ${name} passed"
            total_passed=$((total_passed + 1))
        else
            fail "  ${name} failed"
            total_failed=$((total_failed + 1))
        fi
        echo ""
        draw_hr 60
        echo ""
    done
    
    echo ""
    echo -e "  ${BOLD}Summary:${NC} ${BGREEN}${total_passed} passed${NC}, ${BRED}${total_failed} failed${NC}"
    
    draw_box_end 60 "${YELLOW}"
    echo ""
    
    [[ "$total_failed" -eq 0 ]]
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: world
# ═══════════════════════════════════════════════════════════════════════════════

cmd_world() {
    local action="menu"
    local world_name=""
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --list|-l)     action="list" ;;
            --create|-c)   action="create"; world_name="${2:?--create requires a name}"; shift ;;
            --delete|-d)   action="delete"; world_name="${2:?--delete requires a name}"; shift ;;
            --help|-h)
                echo "Usage: luantis world [--list|--create NAME|--delete NAME]"
                return 0
                ;;
            *)             action="$1" ;;
        esac
        shift
    done
    
    case "$action" in
        list)   world_list ;;
        create) world_create "$world_name" ;;
        delete) world_delete "$world_name" ;;
        menu)   world_menu ;;
    esac
}

world_list() {
    clear_screen
    draw_box "WORLDS" 60 "${CYAN}"
    echo ""
    
    if [[ ! -d "$WORLD_BASE_DIR" ]]; then
        echo -e "  ${DIM}No worlds directory found at ${WORLD_BASE_DIR}${NC}"
        echo -e "  ${DIM}Create one with: ./luantis world --create <name>${NC}"
        draw_box_end 60 "${CYAN}"
        return 0
    fi
    
    local found=0
    for world_dir in "$WORLD_BASE_DIR"/*/; do
        [[ -d "$world_dir" ]] || continue
        found=1
        local wname
        wname="$(basename "$world_dir")"
        local has_meta="no"
        [[ -f "${world_dir}/world.mt" ]] && has_meta="yes"
        
        local meta_color="${BGREEN}"
        [[ "$has_meta" == "no" ]] && meta_color="${BRED}"
        
        printf "  %-30s  world.mt: %s%s%s\n" "$wname" "$meta_color" "$has_meta" "${NC}"
    done
    
    if [[ "$found" -eq 0 ]]; then
        echo -e "  ${DIM}No worlds found${NC}"
    fi
    
    echo ""
    draw_box_end 60 "${CYAN}"
    echo ""
}

world_create() {
    local name="${1:?World name required}"
    local world_dir="${WORLD_BASE_DIR}/${name}"
    
    if [[ -d "$world_dir" ]]; then
        warn "World '${name}' already exists."
        return 0
    fi
    
    step "Creating world '${name}'..."
    mkdir -p "$world_dir" || {
        error "Failed to create world directory."
        return 1
    }
    
    cat > "${world_dir}/world.mt" <<EOF
gameid = devtest
backend = sqlite3
creative_mode = false
enable_damage = true
auth_backend = sqlite3
player_backend = sqlite3
mod_storage_backend = sqlite3
world_name = ${name}
EOF
    
    success "World '${name}' created at ${world_dir}"
}

world_delete() {
    local name="${1:?World name required}"
    local world_dir="${WORLD_BASE_DIR}/${name}"
    
    if [[ ! -d "$world_dir" ]]; then
        warn "World '${name}' does not exist."
        return 1
    fi
    
    if confirm "Delete world '${name}'? This cannot be undone!" "n"; then
        rm -rf "$world_dir"
        success "World '${name}' deleted."
    else
        info "Deletion cancelled."
    fi
}

world_menu() {
    clear_screen
    draw_box "WORLD MANAGEMENT" 60 "${CYAN}"
    echo ""
    menu_item "1" "List worlds" "Show all available worlds"
    menu_item "2" "Create world" "Create a new world"
    menu_item "3" "Delete world" "Delete an existing world"
    menu_item "q" "Back" "Return to main menu"
    echo ""
    draw_box_end 60 "${CYAN}"
    echo ""
    
    read -rp "  ${BOLD}Select [1-3,q]:${NC} " choice
    case "$choice" in
        1) world_list; pause ;;
        2)
            read -rp "  World name: " wname
            [[ -n "$wname" ]] && world_create "$wname"
            pause
            ;;
        3)
            read -rp "  World name to delete: " wname
            [[ -n "$wname" ]] && world_delete "$wname"
            pause
            ;;
        q|Q) return 0 ;;
        *)  echo -e "  ${RED}Invalid choice${NC}"; sleep 1 ;;
    esac
}

