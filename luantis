            ;;
        path)
            echo -e "  ${config_file}"
            ;;
        *)
            echo -e "  ${DIM}Usage: luantis config [show|path]${NC}"
            ;;
    esac
    
    echo ""
    draw_box_end 60 "${CYAN}"
    echo ""
}

