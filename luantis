#!/usr/bin/env bash
#
# luantis — Unified CLI Tool for the Luantis Project
#
# A single entry point for building, configuring, starting, testing,
# and managing the Luantis game engine. Combines all scattered scripts
# into one cohesive, interactive CLI with a beautiful TUI.
#
# Features:
#   - Interactive TUI menu system with colors and keyboard navigation
#   - Dependency checking, installation, and removal
#   - Build client, server, or both with full CMake configuration
#   - Start/stop server and client with all options
#   - World management (create, list, delete)
#   - Run test suites
#   - Git operations (branch, status, log)
#   - Configuration management
#   - Diagnostics and health checks
#   - Non-interactive/CI mode with flags
#
# Usage:
#   ./luantis                          # Interactive TUI menu
#   ./luantis <command> [options]      # Direct command
#   ./luantis --help                   # Show all commands
#
# Commands:
#   build          Build client/server/both
#   start          Start server or client
#   stop           Stop running server
#   status         Show server/client status
#   deps           Check/install/remove dependencies
#   test           Run test suites
#   world          World management (list/create/delete)
#   config         View/edit configuration
#   git            Git operations
#   doctor         Run diagnostics and health checks
#   clean          Clean build artifacts
#   version        Show version info
#
# Examples:
#   ./luantis                                    # Interactive menu
#   ./luantis build --both --release             # Build both
#   ./luantis build --client --debug --clean     # Clean debug client build
#   ./luantis start server --secure              # Start secure server
#   ./luantis start client --go                  # Quick-connect client
#   ./luantis stop                               # Stop server
#   ./luantis deps --check                       # Check dependencies
#   ./luantis deps --install                     # Install missing deps
#   ./luantis test --all                         # Run all tests
#   ./luantis world --list                       # List worlds
#   ./luantis world --create myworld             # Create a world
#   ./luantis doctor                             # Run diagnostics
#   ./luantis clean                              # Clean build dir
#   ./luantis version                            # Show version
#

set -uo pipefail

# Enable pipefail so pipeline exit code reflects the failing command
set -o pipefail

# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILD_DIR="${SCRIPT_DIR}/build"
BIN_DIR="${SCRIPT_DIR}/bin"
WORLD_BASE_DIR="${SCRIPT_DIR}/worlds"
LOG_FILE="${SCRIPT_DIR}/luantis.log"
DEPS_MANIFEST="${SCRIPT_DIR}/.build_deps_installed"

# User-space prefix for locally-installed libraries (no root needed)
# Checks: local-prefix/ next to script, then build/prefix/ (legacy)
LOCAL_PREFIX=""
if [[ -d "${SCRIPT_DIR}/local-prefix" ]]; then
    LOCAL_PREFIX="${SCRIPT_DIR}/local-prefix"
elif [[ -d "${BUILD_DIR}/prefix" ]]; then
    LOCAL_PREFIX="${BUILD_DIR}/prefix"
fi

