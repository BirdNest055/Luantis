    echo -e "    ${CYAN}clean${NC}    Clean build artifacts"
    echo -e "             ${DIM}--deep  Also remove bin/ and logs${NC}"
    echo ""
    echo -e "    ${CYAN}version${NC}  Show version info"
    echo ""
    echo -e "  ${BOLD}Quick Start:${NC}"
    echo ""
    echo -e "    ${GREEN}./luantis deps --install${NC}   ${DIM}# Install all dependencies${NC}"
    echo -e "    ${GREEN}./luantis build --both${NC}      ${DIM}# Build client and server${NC}"
    echo -e "    ${GREEN}./luantis start server${NC}      ${DIM}# Start the server${NC}"
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════════════════

main() {
    # Ensure we're in the right directory
    cd "$SCRIPT_DIR" || {
        error "Cannot change to script directory: $SCRIPT_DIR"
        exit 1
    }
    
    # No arguments → interactive menu
    if [[ $# -eq 0 ]]; then
        show_main_menu
        exit $?
    fi
    
    # Route commands
    local cmd="$1"
    shift || true
    
    case "$cmd" in
        build|b)       cmd_build "$@" ;;
        start|s)       cmd_start "$@" ;;
        stop)          cmd_stop "$@" ;;
        status|st)     cmd_status ;;
        deps|d)        cmd_deps "$@" ;;
        test|t)        cmd_test "$@" ;;
        world|w)       cmd_world "$@" ;;
        config|cfg)    cmd_config "$@" ;;
        git|g)         cmd_git "$@" ;;
        doctor|doc)    cmd_doctor ;;
        clean|cl)      cmd_clean "$@" ;;
        version|ver|v) cmd_version ;;
        help|--help|-h)
            show_help
            ;;
        *)
            error "Unknown command: ${cmd}"
            echo ""
            echo "  Run ${CYAN}./luantis --help${NC} for available commands."
            exit 1
            ;;
    esac
}

main "$@"
