# COLORS & STYLING
# ═══════════════════════════════════════════════════════════════════════════════

RED=$'\033[0;31m'
BRED=$'\033[1;31m'
GREEN=$'\033[0;32m'
BGREEN=$'\033[1;32m'
YELLOW=$'\033[1;33m'
BLUE=$'\033[0;34m'
BBLUE=$'\033[1;34m'
CYAN=$'\033[0;36m'
BCYAN=$'\033[1;36m'
MAGENTA=$'\033[0;35m'
BMAGENTA=$'\033[1;35m'
BOLD=$'\033[1m'
DIM=$'\033[2m'
ITALIC=$'\033[3m'
UNDERLINE=$'\033[4m'
NC=$'\033[0m'
RESET=$'\033[0m'

# Box drawing characters
TL="┌" TR="┐" BL="└" BR="┘" HZ="─" VT="│"
LT="├" RT="┤" TT="┬" BT="┴" CR="┼"

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

log()   { echo -e "${BGREEN}[LUANTIS]${NC} $*" | tee -a "$LOG_FILE" 2>/dev/null; }
warn()  { echo -e "${YELLOW}[WARN]${NC} $*" | tee -a "$LOG_FILE" 2>/dev/null >&2; }
error() { echo -e "${BRED}[ERROR]${NC} $*" | tee -a "$LOG_FILE" 2>/dev/null >&2; }
info()  { echo -e "${BBLUE}[INFO]${NC} $*" | tee -a "$LOG_FILE" 2>/dev/null; }
step()  { echo -e "${BCYAN}[STEP]${NC} $*" | tee -a "$LOG_FILE" 2>/dev/null; }
success() { echo -e "${BGREEN}[OK]${NC} $*" | tee -a "$LOG_FILE" 2>/dev/null; }
fail()  { echo -e "${BRED}[FAIL]${NC} $*" | tee -a "$LOG_FILE" 2>/dev/null >&2; }

# Spinner for long operations
_spin_pid=""
_spin_msg=""
start_spinner() {
    _spin_msg="$1"
    _spin_chars=("⠋" "⠙" "⠹" "⠸" "⠼" "⠴" "⠦" "⠧" "⠇" "⠏")
    _spin_idx=0
    while true; do
        printf "\r  ${CYAN}${_spin_chars[$_spin_idx]}${NC} ${_spin_msg}..."
        _spin_idx=$(( (_spin_idx + 1) % 10 ))
        sleep 0.1
    done &
    _spin_pid=$!
}
stop_spinner() {
    if [[ -n "$_spin_pid" ]]; then
        kill "$_spin_pid" 2>/dev/null || true
        wait "$_spin_pid" 2>/dev/null || true
        _spin_pid=""
        printf "\r%*s\r" 50 ""  # Clear the spinner line
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# TUI COMPONENTS
# ═══════════════════════════════════════════════════════════════════════════════

# Repeat a character N times (handles multibyte/Unicode correctly)
# tr ' ' '─' breaks UTF-8 because tr works byte-by-byte
repeat_char() {
    local char="$1"
    local count="$2"
    local i result=""
    for ((i=0; i<count; i++)); do
        result+="${char}"
    done
    printf '%s' "$result"
}

# Clear screen
clear_screen() {
    printf "\033[2J\033[H"
}

# Draw a horizontal rule
draw_hr() {
    local width="${1:-60}"
    local char="${2:-${HZ}}"
    local color="${3:-${DIM}}"
    echo -e "${color}$(repeat_char "$char" "$width")${NC}"
}

# Draw a box with title
draw_box() {
    local title="$1"
    local width="${2:-60}"
    local color="${3:-${CYAN}}"
    
    echo -e "${color}${TL}$(repeat_char "$HZ" $((width-2)))${TR}${NC}"
    if [[ -n "$title" ]]; then
        local pad=$(( (width - ${#title} - 4) / 2 ))
        [[ $pad -lt 0 ]] && pad=0
        local rpad=$(( width - ${#title} - 4 - pad ))
        echo -e "${color}${VT}${NC}$(printf '%*s' "$pad" '') ${BOLD}${title}${NC} $(printf '%*s' "$rpad" '')${color}${VT}${NC}"
        echo -e "${color}${LT}$(repeat_char "$HZ" $((width-2)))${RT}${NC}"
    fi
}

draw_box_end() {
    local width="${1:-60}"
    local color="${2:-${CYAN}}"
    echo -e "${color}${BL}$(repeat_char "$HZ" $((width-2)))${BR}${NC}"
}

# Print a menu item
menu_item() {
    local key="$1"
    local label="$2"
    local desc="$3"
    local selected="${4:-}"
    
    if [[ "$selected" == "1" ]]; then
        echo -e "  ${BMAGENTA}▸${NC} ${BOLD}${BGREEN}${key}${NC}) ${BOLD}${label}${NC}  ${DIM}${desc}${NC}"
    else
        echo -e "    ${BOLD}${CYAN}${key}${NC}) ${label}${NC}  ${DIM}${desc}${NC}"
    fi
}

# Print a status badge
badge() {
    local label="$1"
    local value="$2"
    local color="${3:-${CYAN}}"
    echo -e "  ${BOLD}${label}:${NC} ${color}${value}${NC}"
}

# Print a key-value pair
kv() {
    local key="$1"
    local value="$2"
    local key_color="${3:-${CYAN}}"
    local val_color="${4:-${NC}}"
    printf "  ${key_color}%-16s${NC} ${val_color}%s${NC}\n" "$key" "$value"
}

# Progress bar
progress_bar() {
    local current="$1"
    local total="$2"
    local width="${3:-30}"
    local label="${4:-}"
    
    local pct=$(( current * 100 / total ))
    local filled=$(( current * width / total ))
    local empty=$(( width - filled ))
    
    local bar_color="${GREEN}"
    [[ $pct -lt 50 ]] && bar_color="${YELLOW}"
    [[ $pct -lt 25 ]] && bar_color="${RED}"
    
    printf "  ${label} ${bar_color}$(repeat_char '█' "$filled")${DIM}$(repeat_char '░' "$empty")${NC} ${BOLD}%3d%%${NC}\n" "$pct"
}

# Confirmation prompt
confirm() {
    local prompt="$1"
    local default="${2:-n}"
    
    local yn=""
    if [[ "$default" == "y" ]]; then
        yn="[Y/n]"
    else
        yn="[y/N]"
    fi
    
    echo ""
    read -rp "  ${BOLD}${prompt}${NC} ${yn} " answer
    answer="${answer:-$default}"
    answer="$(echo "$answer" | tr '[:upper:]' '[:lower:]')"
    
    [[ "$answer" == "y" || "$answer" == "yes" ]]
}

# Pause and wait for Enter
pause() {
    local msg="${1:-Press Enter to continue...}"
    echo ""
    read -rp "  ${DIM}${msg}${NC}" _ || true
}

# ═══════════════════════════════════════════════════════════════════════════════
# VERSION DETECTION
# ═══════════════════════════════════════════════════════════════════════════════

get_version() {
    if [[ -f "${SCRIPT_DIR}/CMakeLists.txt" ]]; then
        local major minor patch extra
        major="$(grep '^set(VERSION_MAJOR' "${SCRIPT_DIR}/CMakeLists.txt" | tr -dC 0-9)"
        minor="$(grep '^set(VERSION_MINOR' "${SCRIPT_DIR}/CMakeLists.txt" | tr -dC 0-9)"
        patch="$(grep '^set(VERSION_PATCH' "${SCRIPT_DIR}/CMakeLists.txt" | tr -dC 0-9)"
        extra="$(grep '^set(VERSION_EXTRA' "${SCRIPT_DIR}/CMakeLists.txt" | sed 's/set(VERSION_EXTRA "\([^"]*\)".*/\1/' | head -1)"
        echo "${major}.${minor}.${patch}${extra:+-}${extra}"
    else
        echo "unknown"
    fi
}

get_git_branch() {
    cd "$SCRIPT_DIR" 2>/dev/null || return
    git branch --show-current 2>/dev/null || echo "unknown"
}

get_git_status() {
    cd "$SCRIPT_DIR" 2>/dev/null || return
    local dirty
    dirty="$(git status --porcelain 2>/dev/null | wc -l)"
    if [[ "$dirty" -eq 0 ]]; then
        echo "clean"
    else
        echo "${dirty} changes"
    fi
}

# ═══════════════════════════════════════════════════════════════════════════════
# DISTRO DETECTION
# ═══════════════════════════════════════════════════════════════════════════════

detect_distro() {
    if [[ -f /etc/os-release ]]; then
        # shellcheck disable=SC1091
        source /etc/os-release 2>/dev/null
        echo "${ID}"
    elif command -v lsb_release &>/dev/null; then
        lsb_release -is 2>/dev/null | tr '[:upper:]' '[:lower:]'
    elif [[ -f /etc/debian_version ]]; then
        echo "debian"
    elif [[ -f /etc/fedora-release ]]; then
        echo "fedora"
    elif [[ -f /etc/arch-release ]]; then
        echo "arch"
    elif [[ -f /etc/alpine-release ]]; then
        echo "alpine"
    else
        echo "unknown"
    fi
}

DISTRO="$(detect_distro)"

# ═══════════════════════════════════════════════════════════════════════════════
# USER-SPACE PREFIX HELPERS
# ═══════════════════════════════════════════════════════════════════════════════

# Augment PKG_CONFIG_PATH with any user-space prefix .pc directories
# so that deps --check and CMake can find locally-installed libraries
setup_pkg_config_path() {
    local -a pc_dirs=()
    for d in "${LOCAL_PREFIX}/lib/pkgconfig" "${LOCAL_PREFIX}/usr/lib/x86_64-linux-gnu/pkgconfig" "${LOCAL_PREFIX}/lib/x86_64-linux-gnu/pkgconfig"; do
        [[ -d "$d" ]] && pc_dirs+=("$d")
    done
    if [[ "${#pc_dirs[@]}" -gt 0 ]]; then
        local joined_pc
        joined_pc="$(IFS=:; echo "${pc_dirs[*]}")"
        export PKG_CONFIG_PATH="${joined_pc}:${PKG_CONFIG_PATH:-}"
    fi
}
setup_pkg_config_path

# ═══════════════════════════════════════════════════════════════════════════════
# PACKAGE MANAGEMENT
# ═══════════════════════════════════════════════════════════════════════════════

pkg_is_installed() {
    local pkg="$1"
    case "$DISTRO" in
        debian|ubuntu|linuxmint|pop|elementary|kali)
            dpkg -s "$pkg" &>/dev/null ;;
        fedora|rhel|centos|rocky|alma|oracle)
            rpm -q "$pkg" &>/dev/null ;;
        arch|manjaro|endeavouros|garuda)
            pacman -Qi "$pkg" &>/dev/null ;;
        alpine)
            apk info -e "$pkg" &>/dev/null ;;
        *)
            return 1 ;;
    esac
}

install_packages() {
    local -a pkgs=("$@")
    if ! command -v sudo &>/dev/null; then
        error "sudo is not available. Cannot install packages automatically."
        error "Please install manually: ${pkgs[*]}"
        return 1
    fi
    
    step "Installing ${#pkgs[@]} packages..."
    case "$DISTRO" in
        debian|ubuntu|linuxmint|pop|elementary|kali)
            sudo apt-get update -qq 2>/dev/null
            sudo apt-get install -y "${pkgs[@]}" 2>&1 | tail -5
            ;;
        fedora|rhel|centos|rocky|alma|oracle)
            sudo dnf install -y "${pkgs[@]}" 2>&1 | tail -5
            ;;
        arch|manjaro|endeavouros|garuda)
            sudo pacman -S --needed --noconfirm "${pkgs[@]}" 2>&1 | tail -5
            ;;
        alpine)
            sudo apk add "${pkgs[@]}" 2>&1 | tail -5
            ;;
        *)
            error "Unsupported distro: ${DISTRO}"
            return 1
            ;;
    esac
}

