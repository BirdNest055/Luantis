# Core dependencies (required for any build)
CORE_DEPS_TOOLS=(cmake g++ pkg-config)
CORE_DEPS_LIBS=(zlib libzstd sqlite3 gmp openssl jsoncpp luajit)

# Client-only dependencies
CLIENT_DEPS_TOOLS=()
CLIENT_DEPS_LIBS=(freetype2 gl sdl2 openal vorbis ogg jpeg png curl)

# Server-only dependencies (curl is shared with client; listed here for server-only builds)
SERVER_DEPS_TOOLS=()
SERVER_DEPS_LIBS=(curl ncurses)

# Map logical lib name to pkg-config name
# (Some .pc files use different names: curl→libcurl, png→libpng, jpeg→libjpeg)
lib_to_pc() {
    local lib="$1"
    case "$lib" in
        curl)       echo "libcurl" ;;
        png)        echo "libpng" ;;
        jpeg)       echo "libjpeg" ;;
        ncurses)    echo "ncursesw" ;;
        *)          echo "$lib" ;;
    esac
}

# Check if a library is available via pkg-config (tries both logical and mapped name)
pc_exists() {
    local lib="$1"
    local pc_name
    pc_name="$(lib_to_pc "$lib")"
    # Try the mapped name first, then the raw name as fallback
    pkg-config --exists "$pc_name" 2>/dev/null || pkg-config --exists "$lib" 2>/dev/null
}

# Get the modversion of a library via pkg-config
pc_modversion() {
    local lib="$1"
    local pc_name
    pc_name="$(lib_to_pc "$lib")"
    pkg-config --modversion "$pc_name" 2>/dev/null || pkg-config --modversion "$lib" 2>/dev/null || echo "?"
}

