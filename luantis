# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: doctor
# ═══════════════════════════════════════════════════════════════════════════════

cmd_doctor() {
    clear_screen
    draw_box "LUANTIS DOCTOR — DIAGNOSTICS" 60 "${YELLOW}"
    echo ""
    
    local issues=0
    
    # 1. Check CMakeLists.txt exists
    echo -e "  ${BOLD}1. Project Files${NC}"
    if [[ -f "${SCRIPT_DIR}/CMakeLists.txt" ]]; then
        echo -e "    ${BGREEN}✓${NC} CMakeLists.txt found"
    else
        echo -e "    ${BRED}✗${NC} CMakeLists.txt missing"
        issues=$((issues + 1))
    fi
    
    if [[ -f "${SCRIPT_DIR}/src/CMakeLists.txt" ]]; then
        echo -e "    ${BGREEN}✓${NC} src/CMakeLists.txt found"
    else
        echo -e "    ${BRED}✗${NC} src/CMakeLists.txt missing"
        issues=$((issues + 1))
    fi
    echo ""
    
    # 2. Check build tools
    echo -e "  ${BOLD}2. Build Tools${NC}"
    for tool in cmake g++ pkg-config git; do
        if command -v "$tool" &>/dev/null; then
            local ver
            ver="$($tool --version 2>/dev/null | head -1)" || ver="found"
            echo -e "    ${BGREEN}✓${NC} ${tool}: ${DIM}${ver}${NC}"
        else
            echo -e "    ${BRED}✗${NC} ${tool}: NOT FOUND"
            issues=$((issues + 1))
        fi
    done
    echo ""
    
    # 3. Check build environment
    echo -e "  ${BOLD}3. Build Environment${NC}"
    if [[ -d "$BUILD_DIR" ]]; then
        echo -e "    ${BGREEN}✓${NC} Build directory exists"
        if [[ -f "${BUILD_DIR}/CMakeCache.txt" ]]; then
            echo -e "    ${BGREEN}✓${NC} CMake cache present"
        else
            echo -e "    ${YELLOW}!${NC} No CMake cache (need to configure)"
        fi
    else
        echo -e "    ${YELLOW}!${NC} Build directory not created yet"
    fi
    echo ""
    
    # 4. Check binaries
    echo -e "  ${BOLD}4. Built Binaries${NC}"
    local client_bin server_bin
    client_bin="$(find_client_binary 2>/dev/null)" || true
    server_bin="$(find_server_binary 2>/dev/null)" || true
    
    if [[ -n "$client_bin" ]]; then
        local cver
        cver="$("$client_bin" --version 2>/dev/null | head -1)" || cver="found"
        echo -e "    ${BGREEN}✓${NC} Client: ${cver}"
    else
        echo -e "    ${YELLOW}!${NC} Client not built"
    fi
    
    if [[ -n "$server_bin" ]]; then
        local sver
        sver="$("$server_bin" --version 2>/dev/null | head -1)" || sver="found"
        echo -e "    ${BGREEN}✓${NC} Server: ${sver}"
    else
        echo -e "    ${YELLOW}!${NC} Server not built"
    fi
    echo ""
    
    # 5. Check scripts
    echo -e "  ${BOLD}5. Helper Scripts${NC}"
    for script in build_linux.sh start_server.sh start_client.sh build_env.sh; do
        if [[ -f "${SCRIPT_DIR}/${script}" ]]; then
            echo -e "    ${BGREEN}✓${NC} ${script}"
        else
            echo -e "    ${BRED}✗${NC} ${script} missing"
            issues=$((issues + 1))
        fi
    done
    echo ""
    
    # 6. Check disk space
    echo -e "  ${BOLD}6. Disk Space${NC}"
    local avail
    avail="$(df -h "$SCRIPT_DIR" 2>/dev/null | tail -1 | awk '{print $4}')"
    echo -e "    Available: ${avail}"
    echo ""
    
    # 7. Check for path issues
    echo -e "  ${BOLD}7. Path Safety${NC}"
    local _path_has_special=false
    for (( _i=0; _i<${#SCRIPT_DIR}; _i++ )); do
        _c="${SCRIPT_DIR:$_i:1}"
        case "$_c" in
            ' '|'('|')'|'&'|';'|'`'|'!'|'$'|'<'|'>'|'|'|'\'|"'"|'"') _path_has_special=true; break ;;
        esac
    done
    if [[ "$_path_has_special" == "true" ]]; then
        echo -e "    ${YELLOW}!${NC} Path contains special characters (may break CMake)"
        issues=$((issues + 1))
    else
        echo -e "    ${BGREEN}✓${NC} Path is safe: ${SCRIPT_DIR}"
    fi
    echo ""
    
    # 8. OpenSSL version (needed for Ed25519 + AES-256-GCM)
    echo -e "  ${BOLD}8. OpenSSL Version${NC}"
    if command -v openssl &>/dev/null; then
        local ossl_ver
        ossl_ver="$(openssl version 2>/dev/null)" || ossl_ver="unknown"
        echo -e "    ${ossl_ver}"
        if echo "$ossl_ver" | grep -qE '3\.[0-9]'; then
            echo -e "    ${BGREEN}✓${NC} OpenSSL 3.x (Ed25519 + AES-256-GCM supported)"
        else
            echo -e "    ${YELLOW}!${NC} OpenSSL < 3.0 (may lack Ed25519/AES-256-GCM)"
            issues=$((issues + 1))
        fi
    else
        echo -e "    ${BRED}✗${NC} openssl not found"
        issues=$((issues + 1))
    fi
    echo ""
    
    draw_hr 60
    echo ""
    
    if [[ "$issues" -eq 0 ]]; then
        success "No issues found! Everything looks healthy."
    else
        warn "${issues} issue(s) found. Review above for details."
    fi
    
    draw_box_end 60 "${YELLOW}"
    echo ""
}

# ═══════════════════════════════════════════════════════════════════════════════
# COMMAND: clean
# ═══════════════════════════════════════════════════════════════════════════════

cmd_clean() {
    local deep=0
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --deep|-d) deep=1 ;;
            --help|-h)
                echo "Usage: luantis clean [--deep]"
                echo "  --deep  Also remove bin/ directory and log files"
                return 0
                ;;
        esac
        shift
    done
    
    step "Cleaning build directory..."
    # Preserve any user-space prefix directory inside build/ (build/prefix/)
    # Note: local-prefix/ at the project root is NOT affected since it's outside build/
    local prefix_backup=""
    if [[ -d "${BUILD_DIR}/prefix" ]]; then
        prefix_backup="$(mktemp -d /tmp/luantis_prefix_XXXXXX)"
        step "Preserving user-space prefix at ${BUILD_DIR}/prefix..."
        # Copy contents of prefix dir into backup (not the dir itself)
        cp -a "${BUILD_DIR}/prefix/." "${prefix_backup}/" || warn "Failed to backup prefix"
    fi
    rm -rf "$BUILD_DIR"
    if [[ -n "$prefix_backup" && -d "$prefix_backup" ]]; then
        mkdir -p "${BUILD_DIR}/prefix"
        # Restore prefix contents from backup
        cp -a "${prefix_backup}/." "${BUILD_DIR}/prefix/" || warn "Failed to restore prefix"
        rm -rf "$prefix_backup"
        success "User-space prefix preserved."
    fi
    success "Build directory cleaned."
    
    if [[ "$deep" -eq 1 ]]; then
        step "Deep clean: removing bin/ directory..."
        rm -rf "$BIN_DIR"
        success "Bin directory cleaned."
        
        step "Removing log files..."
        rm -f "${SCRIPT_DIR}"/*.log
        rm -f "${SCRIPT_DIR}"/build_linux.log
        success "Log files cleaned."
    fi
    
    echo ""
    info "Run ${CYAN}./luantis build${NC} to rebuild."
}

